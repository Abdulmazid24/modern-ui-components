{
  "name": "@modern-ui/cli",
  "version": "1.0.0",
  "description": "CLI tool for installing Modern UI Vault components",
  "main": "dist/index.js",
  "bin": {
    "modern-ui-vault": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --minify",
    "dev": "tsup src/index.ts --format cjs --watch",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "node-fetch": "^2.7.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-fetch": "^2.6.9",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.0.1",
    "typescript": "^5.3.0"
  }
}
