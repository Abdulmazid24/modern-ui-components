{
  "name": "modern-ui-vault",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=@vault/storefront",
    "build": "npm run build --workspaces",
    "registry:build": "npx tsx scripts/build-registry.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run lint --workspaces"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.4"
  }
}
